---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const sponsorships = await getCollection('sponsorships');
const interviews = await getCollection('interviews');
const blog = await getCollection('blog');

const featuredSponsors = sponsorships
  .filter((s) => s.data.featured)
  .sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime())
  .slice(0, 3);

const recentBlog = blog
  .sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime())
  .slice(0, 3);

const recentInterviews = interviews
  .sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime())
  .slice(0, 3);

const categories = [
  {
    name: 'Sponsorships',
    slug: 'sponsorships',
    description: '100+ sponsorship opportunities for streamers',
    count: sponsorships.length,
    icon: '💰',
  },
  {
    name: 'Analytics',
    slug: 'analytics',
    description: 'Track and analyze your stream performance',
    count: (await getCollection('analytics')).length,
    icon: '📊',
  },
  {
    name: 'Bots',
    slug: 'bots',
    description: 'Chat moderation and engagement tools',
    count: (await getCollection('bots')).length,
    icon: '🤖',
  },
  {
    name: 'Music',
    slug: 'music',
    description: 'Free music for your streams',
    count: (await getCollection('music')).length,
    icon: '🎵',
  },
  {
    name: 'Graphics',
    slug: 'graphics',
    description: 'Overlays and graphic design tools',
    count: (await getCollection('graphics')).length,
    icon: '🎨',
  },
  {
    name: 'Broadcast Tools',
    slug: 'stream-software',
    description: 'Software for broadcasting',
    count: (await getCollection('broadcast-tools')).length,
    icon: '📹',
  },
  {
    name: 'Streaming Tools',
    slug: 'twitch-tools',
    description: 'Platform-specific tools and extensions',
    count: (await getCollection('streaming-tools')).length,
    icon: '⚙️',
  },
];
---

<BaseLayout
  title="Fairly Odd Streamers - Resources for Livestreamers"
  description="Discover sponsorships, tools, analytics, and resources for livestreamers. Over 100 curated sponsorship opportunities."
>

<div class="hero section">
  <div class="container">
    <h1>Fairly Odd Streamers</h1>
    <p class="hero-subtitle">Curated resources, sponsorships, and tools to help you succeed at streaming</p>
    <a href="/resources/sponsorships/" class="btn btn-primary">Explore Sponsorships</a>
  </div>
</div>

<div class="section">
  <div class="container">
    <h2 style="text-align: center; margin-bottom: 3rem;">Resource Categories</h2>
    <div class="grid grid-3">
      {
        categories.map((cat) => (
          <a href={`/resources/${cat.slug}/`} class="card" style="text-decoration: none;">
            <div style="font-size: 2.5rem; margin-bottom: 1rem;">{cat.icon}</div>
            <h3 style="margin-bottom: 0.5rem; color: #ffffff;">{cat.name}</h3>
            <p>{cat.description}</p>
            <p style="margin-top: 1rem; color: #a855f7; font-weight: 600;">{cat.count} Resources →</p>
          </a>
        ))
      }
    </div>
  </div>
</div>

{
  featuredSponsors.length > 0 && (
    <div class="section" style="background-color: var(--bg-secondary);">
      <div class="container">
        <h2 style="text-align: center; margin-bottom: 3rem;">Featured Sponsorships</h2>
        <div class="grid grid-3">
          {featuredSponsors.map((sponsor) => (
            <a href={`/resources/sponsorships/${sponsor.slug}/`} class="card" style="text-decoration: none;">
              {sponsor.data.logo && (
                <img
                  src={sponsor.data.logo}
                  alt={sponsor.data.name}
                  style="max-height: 80px; object-fit: contain; margin-bottom: 1rem;"
                />
              )}
              <h3 style="color: #ffffff; margin-bottom: 0.5rem;">{sponsor.data.name}</h3>
              <p class="line-clamp-2">{sponsor.data.category}</p>
              {sponsor.data.compensation && (
                <p style="color: #a855f7; font-weight: 600; margin-top: 1rem;">{sponsor.data.compensation}</p>
              )}
            </a>
          ))}
        </div>
        <div style="text-align: center; margin-top: 2rem;">
          <a href="/resources/sponsorships/" class="btn btn-primary">
            View All Sponsorships
          </a>
        </div>
      </div>
    </div>
  )
}

{
  recentBlog.length > 0 && (
    <div class="section">
      <div class="container">
        <h2 style="text-align: center; margin-bottom: 3rem;">Latest Blog Posts</h2>
        <div class="grid grid-2">
          {recentBlog.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card" style="text-decoration: none;">
              {post.data.coverImage && (
                <img
                  src={post.data.coverImage}
                  alt={post.data.name}
                  style="width: 100%; height: 200px; object-fit: cover; margin: -1rem -1rem 1rem -1rem; border-radius: 0.75rem 0.75rem 0 0;"
                />
              )}
              <h3 style="color: #ffffff; margin-bottom: 0.5rem;">{post.data.name}</h3>
              <p class="line-clamp-2">{post.data.postSummary || ''}</p>
              <div style="margin-top: 1rem; display: flex; justify-content: space-between; align-items: center;">
                {post.data.author && <span style="color: #a855f7;">{post.data.author}</span>}
                {post.data.readTime && <span style="color: #b0b0b8; font-size: 0.875rem;">{post.data.readTime}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )
}

{
  recentInterviews.length > 0 && (
    <div class="section" style="background-color: var(--bg-secondary);">
      <div class="container">
        <h2 style="text-align: center; margin-bottom: 3rem;">Recent Interviews</h2>
        <div class="grid grid-2">
          {recentInterviews.map((interview) => (
            <a href={`/interviews/${interview.slug}/`} class="card" style="text-decoration: none;">
              {interview.data.coverPhoto && (
                <img
                  src={interview.data.coverPhoto}
                  alt={interview.data.name}
                  style="width: 100%; height: 250px; object-fit: cover; margin: -1rem -1rem 1rem -1rem; border-radius: 0.75rem 0.75rem 0 0;"
                />
              )}
              <h3 style="color: #ffffff; margin-bottom: 0.5rem;">{interview.data.name}</h3>
              <p class="line-clamp-2">{interview.data.title || interview.data.category}</p>
              <div style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                {interview.data.twitch && (
                  <span class="badge badge-secondary" style="font-size: 0.7rem;">Twitch</span>
                )}
                {interview.data.twitter && (
                  <span class="badge badge-secondary" style="font-size: 0.7rem;">Twitter</span>
                )}
                {interview.data.youtube && (
                  <span class="badge badge-secondary" style="font-size: 0.7rem;">YouTube</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )
}

<!-- Newsletter Signup -->
<div class="section">
  <div class="container">
    <div style="max-width: 600px; margin: 0 auto; text-align: center; padding: 3rem 2rem; background: linear-gradient(135deg, rgba(168,85,247,0.15), rgba(236,72,153,0.15)); border: 1px solid rgba(168,85,247,0.3); border-radius: 1rem;">
      <h2 style="margin-bottom: 0.5rem;">Stay in the Loop</h2>
      <p style="font-size: 1.1rem; color: #b0b0b8; margin-bottom: 1.5rem;">
        Get the latest sponsorship opportunities, tools, and streamer tips delivered to your inbox.
      </p>
      <form action="https://formsubmit.co/brian@fairlyoddstreamers.com" method="POST" style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <input type="text" name="_honey" style="display:none">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_subject" value="New FOS Newsletter Signup">
        <input type="hidden" name="_next" value="https://fairlyoddstreamers.com/?subscribed=true">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          style="padding: 0.75rem 1rem; min-width: 280px; font-size: 1rem;"
        />
        <button type="submit" class="btn btn-primary" style="padding: 0.75rem 1.5rem; font-size: 1rem;">
          Subscribe
        </button>
      </form>
      <p style="font-size: 0.8rem; color: #666; margin-top: 1rem; margin-bottom: 0;">No spam, unsubscribe anytime.</p>
    </div>
  </div>
</div>
</BaseLayout>
