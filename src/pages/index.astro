---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const sponsorships = await getCollection('sponsorships');
const interviews = await getCollection('interviews');
const blog = await getCollection('blog');

const featuredSponsors = sponsorships
  .filter((s) => s.data.featured)
  .sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime())
  .slice(0, 3);

const recentBlog = blog
  .sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime())
  .slice(0, 3);

const recentInterviews = interviews
  .sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime())
  .slice(0, 3);

const categories = [
  {
    name: 'Sponsorships',
    slug: 'sponsorships',
    description: 'Browse 100+ brands offering sponsorships or affiliate opportunities.',
    image: '/images/RESOURCE-sponsorships.png',
  },
  {
    name: 'Analytics',
    slug: 'analytics',
    description: 'Track and analyze your stream performance.',
    image: '/images/RESOURCE-analytics.png',
  },
  {
    name: 'Bots',
    slug: 'bots',
    description: 'Chat moderation and engagement tools.',
    image: '/images/RESOURCE-bots.png',
  },
  {
    name: 'Music',
    slug: 'music',
    description: "Stream-safe music without DMCA worries.",
    image: '/images/RESOURCE-music.png',
  },
  {
    name: 'Graphics',
    slug: 'graphics',
    description: 'Overlays, alerts, and graphic design tools.',
    image: '/images/RESOURCE-graphics.png',
  },
  {
    name: 'Broadcast Tools',
    slug: 'stream-software',
    description: 'The best software for going live.',
    image: '/images/RESOURCE-software.png',
  },
  {
    name: 'Streaming Tools',
    slug: 'twitch-tools',
    description: 'Platform-specific tools and extensions.',
    image: '/images/RESOURCE-tools.png',
  },
];

const testimonials = [
  {
    text: "I was interviewed by @fairlyoddstream and they were amazing to work with :D Please go read our interview.",
    name: "Kayk",
    handle: "Kaykrisify",
    role: "Twitch Partner",
  },
  {
    text: "Saw this on TikTok and ya'll deserve to know. This website has everything you might need in terms of streamer resources. It's a blessing for new streamers.",
    name: "Kain",
    handle: "vtuber",
    role: "",
  },
  {
    text: "Fairly Odd Streamers has a big list of sponsors known to sponsor streamers, and is another great resource :)",
    name: "Kati",
    handle: "Katliente",
    role: "Twitch Partner",
  },
  {
    text: "Thank you for this cool opportunity to do an interview! @fairlyoddstream is a wonderful resource for all streamers alike from the basics to sponsorships!",
    name: "Mini",
    handle: "MinishKat",
    role: "Twitch & NZXT Partner",
  },
  {
    text: "@fairlyoddstream — the master site for sponsorships and affiliations. Provides access to over 100 different sponsorships with info on the company, requirements, and the link to apply!",
    name: "Ariq",
    handle: "Aziouxeen",
    role: "Twitch Streamer",
  },
  {
    text: "The website of Fairly Odd Streamers is a great resource for applying for some sponsorships!",
    name: "Cari",
    handle: "Carlewheezers",
    role: "Horror & Variety Streamer",
  },
];
---

<BaseLayout
  title="Fairly Odd Streamers - Resources for Livestreamers"
  description="Discover sponsorships, tools, analytics, and resources for livestreamers. Over 100 curated sponsorship opportunities."
>

<!-- Hero -->
<div class="hero-section">
  <div class="container">
    <div class="hero-split">
      <div class="hero-content">
        <h1 class="hero-heading">
          Stop <span class="hero-highlight">Wishing</span><br>
          Your Way to Stardom
        </h1>
        <p class="hero-sub">We're curating the best tools and content to help you become a successful livestreamer.</p>
        <form class="hero-form" action="https://formsubmit.co/brian@fairlyoddstreamers.com" method="POST">
          <input type="text" name="_honey" style="display:none">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_subject" value="New FOS Newsletter Signup">
          <input type="hidden" name="_next" value="https://fairlyoddstreamers.com/?subscribed=true">
          <input type="email" name="email" placeholder="Email" required />
          <button type="submit" class="btn btn-gold">Sign Up</button>
        </form>
        <p class="hero-disclaimer">Get weekly tips sent straight to your inbox!</p>
      </div>
      <div class="hero-image">
        <img src="/images/FOS-TV-Static.gif" alt="Fairly Odd Streamers TV" />
      </div>
    </div>
  </div>
</div>

<!-- Platform Bar -->
<div class="platform-bar">
  <p class="platform-bar-text">Applies to all major streaming platforms</p>
  <div class="platform-logos">
    <span class="platform-tag">Twitch</span>
    <span class="platform-tag">YouTube</span>
    <span class="platform-tag">Facebook Gaming</span>
    <span class="platform-tag">Kick</span>
  </div>
</div>

<!-- Resource Categories -->
<div class="section">
  <div class="container">
    <h2 class="section-heading-display">No Magic Necessary</h2>
    <p class="section-subheading">All the information you need to grow your channel, in one place.</p>
    <div class="grid grid-4">
      {categories.map((cat) => (
        <a href={`/resources/${cat.slug}/`} class="category-card">
          <img src={cat.image} alt={cat.name} class="category-card-img" loading="lazy" />
          <div class="category-card-body">
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </div>
        </a>
      ))}
    </div>
    <div class="cta-center" style="margin-top: var(--spacing-2xl);">
      <a href="/resources/" class="btn btn-outline-green">Take Me To The Resource Center</a>
    </div>
  </div>
</div>

<!-- Featured Sponsorships -->
{
  featuredSponsors.length > 0 && (
    <div class="section section-alt">
      <div class="container">
        <h2 class="section-heading-display">Featured Sponsorships</h2>
        <div class="grid grid-3">
          {featuredSponsors.map((sponsor) => (
            <a href={`/resources/sponsorships/${sponsor.slug}/`} class="card card-link">
              {sponsor.data.logo && (
                <img
                  src={sponsor.data.logo}
                  alt={sponsor.data.name}
                  style="max-height: 80px; object-fit: contain; margin-bottom: 1rem;"
                  loading="lazy"
                />
              )}
              <h3 class="card-title">{sponsor.data.name}</h3>
              <p class="line-clamp-2">{sponsor.data.category}</p>
              {sponsor.data.compensation && (
                <p class="text-accent mt-2">{sponsor.data.compensation}</p>
              )}
            </a>
          ))}
        </div>
        <div class="cta-center">
          <a href="/resources/sponsorships/" class="btn btn-primary">
            View All Sponsorships
          </a>
        </div>
      </div>
    </div>
  )
}

<!-- Latest Blog Posts -->
{
  recentBlog.length > 0 && (
    <div class="section">
      <div class="container">
        <h2 class="section-heading-display">Latest From The Blog</h2>
        <div class="grid grid-2">
          {recentBlog.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card card-link">
              {post.data.coverImage && (
                <img
                  src={post.data.coverImage}
                  alt={post.data.name}
                  class="card-img"
                  loading="lazy"
                />
              )}
              <h3 class="card-title">{post.data.name}</h3>
              <p class="line-clamp-2">{post.data.postSummary || ''}</p>
              <div class="card-meta">
                {post.data.author && <span class="text-accent">{post.data.author}</span>}
                {post.data.readTime && <span>{post.data.readTime}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )
}

<!-- Recent Interviews -->
{
  recentInterviews.length > 0 && (
    <div class="section section-alt">
      <div class="container">
        <h2 class="section-heading-display">Recent Interviews</h2>
        <div class="grid grid-2">
          {recentInterviews.map((interview) => (
            <a href={`/interviews/${interview.slug}/`} class="card card-link">
              {interview.data.coverPhoto && (
                <img
                  src={interview.data.coverPhoto}
                  alt={interview.data.name}
                  class="card-img card-img-tall"
                  loading="lazy"
                />
              )}
              <h3 class="card-title">{interview.data.name}</h3>
              <p class="line-clamp-2">{interview.data.title || interview.data.category}</p>
              <div class="badge-row">
                {interview.data.twitch && (
                  <span class="badge badge-secondary badge-sm">Twitch</span>
                )}
                {interview.data.twitter && (
                  <span class="badge badge-secondary badge-sm">Twitter</span>
                )}
                {interview.data.youtube && (
                  <span class="badge badge-secondary badge-sm">YouTube</span>
                )}
              </div>
            </a>
          ))}
        </div>
        <div class="cta-center">
          <a href="/interviews/" class="btn btn-secondary">View All Interviews</a>
        </div>
      </div>
    </div>
  )
}

<!-- Testimonials -->
<div class="testimonials-section">
  <div class="container">
    <h2 class="section-heading-display">
      Thousands of Creators<br>Love Fairly Odd Streamers
    </h2>
    <div class="testimonial-grid">
      {testimonials.map((t) => (
        <div class="testimonial-card">
          <p class="testimonial-text">"{t.text}"</p>
          <p class="testimonial-author-name">{t.name}</p>
          <p class="testimonial-author-handle">{t.handle}</p>
          {t.role && <p class="testimonial-author-role">{t.role}</p>}
        </div>
      ))}
    </div>
  </div>
</div>

<!-- Newsletter -->
<div class="section">
  <div class="container">
    <div class="newsletter-box">
      <h2>Stay in the Loop</h2>
      <p class="page-subtitle">
        Get the latest sponsorship opportunities, tools, and streamer tips delivered to your inbox.
      </p>
      <form action="https://formsubmit.co/brian@fairlyoddstreamers.com" method="POST" class="newsletter-form">
        <input type="text" name="_honey" style="display:none">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_subject" value="New FOS Newsletter Signup">
        <input type="hidden" name="_next" value="https://fairlyoddstreamers.com/?subscribed=true">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
        />
        <button type="submit" class="btn btn-primary">
          Subscribe
        </button>
      </form>
      <p class="newsletter-disclaimer">No spam, unsubscribe anytime.</p>
    </div>
  </div>
</div>

</BaseLayout>
