---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - Fairly Odd Streamers" description="The page you're looking for doesn't exist.">
  <div class="section">
    <div class="container">
      <div class="error-page">
        <h1>404</h1>
        <h2>Page Not Found</h2>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <div>
          <a href="/" class="btn btn-primary">Go Home</a>
          <a href="/resources/sponsorships/" class="btn btn-secondary" style="margin-left: 1rem;">Browse Sponsorships</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
