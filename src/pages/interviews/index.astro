---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const interviews = await getCollection('interviews');
const sorted = interviews.sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime());
---

<BaseLayout
  title="Interviews - Fairly Odd Streamers"
  description="Interviews with top streamers. Learn about their strategies, tools, and experiences in the streaming world."
>

<div class="section-narrow">
  <div class="container">
    <div class="page-header">
      <h1>Streamer Interviews</h1>
    </div>
    <p class="page-subtitle">
      In-depth interviews with top creators in the streaming community.
    </p>

    {
      sorted.length > 0 ? (
        <div class="grid grid-2">
          {sorted.map((interview) => (
            <a href={`/interviews/${interview.slug}/`} class="card card-link">
              {interview.data.coverPhoto && (
                <img
                  src={interview.data.coverPhoto}
                  alt={interview.data.name}
                  class="card-img card-img-tall"
                />
              )}
              <h3 class="card-title">{interview.data.name}</h3>
              {interview.data.title && <p>{interview.data.title}</p>}
              {interview.data.category && <p class="text-accent">{interview.data.category}</p>}
              <div class="badge-row">
                {interview.data.twitch && <span class="badge badge-secondary badge-sm">Twitch</span>}
                {interview.data.twitter && <span class="badge badge-secondary badge-sm">Twitter</span>}
                {interview.data.youtube && <span class="badge badge-secondary badge-sm">YouTube</span>}
                {interview.data.instagram && <span class="badge badge-secondary badge-sm">Instagram</span>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">No interviews found.</p>
      )
    }
  </div>
</div>
</BaseLayout>
