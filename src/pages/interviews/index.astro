---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const interviews = await getCollection('interviews');
const sorted = interviews.sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime());
---

<BaseLayout
  title="Interviews - Fairly Odd Streamers"
  description="Interviews with top streamers. Learn about their strategies, tools, and experiences in the streaming world."
>

<div class="section-narrow">
  <div class="container">
    <h1 style="margin-bottom: 1rem;">Streamer Interviews</h1>
    <p style="font-size: 1.1rem; color: #b0b0b8; margin-bottom: 3rem;">
      In-depth interviews with top creators in the streaming community.
    </p>

    {
      sorted.length > 0 ? (
        <div class="grid grid-2">
          {sorted.map((interview) => (
            <a href={`/interviews/${interview.slug}/`} class="card" style="text-decoration: none; display: block;">
              {interview.data.coverPhoto && (
                <img
                  src={interview.data.coverPhoto}
                  alt={interview.data.name}
                  style="width: 100%; height: 250px; object-fit: cover; margin: -1rem -1rem 1rem -1rem; border-radius: 0.75rem 0.75rem 0 0;"
                />
              )}
              <h3 style="color: #ffffff; margin-bottom: 0.5rem;">{interview.data.name}</h3>
              {interview.data.title && <p>{interview.data.title}</p>}
              {interview.data.category && <p style="color: #a855f7; font-weight: 600; margin-top: 0.5rem;">{interview.data.category}</p>}
              <div style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                {interview.data.twitch && <span class="badge badge-secondary" style="font-size: 0.7rem;">Twitch</span>}
                {interview.data.twitter && <span class="badge badge-secondary" style="font-size: 0.7rem;">Twitter</span>}
                {interview.data.youtube && <span class="badge badge-secondary" style="font-size: 0.7rem;">YouTube</span>}
                {interview.data.instagram && <span class="badge badge-secondary" style="font-size: 0.7rem;">Instagram</span>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: #b0b0b8;">No interviews found.</p>
      )
    }
  </div>
</div>
</BaseLayout>
