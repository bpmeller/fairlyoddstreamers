---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const interviews = await getCollection('interviews');
  return interviews.map((interview) => ({
    params: { slug: interview.slug },
    props: { interview },
  }));
}

const { interview } = Astro.props;
const { Content } = await interview.render();
---

<BaseLayout
  title={`Interview: ${interview.data.name} - Fairly Odd Streamers`}
  description={`Interview with ${interview.data.name}. ${interview.data.title || interview.data.category}`}
  ogImage={interview.data.coverPhoto || interview.data.ogImage}
>

<div class="section-narrow">
  <div class="container">
    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/interviews/">Interviews</a>
      <span class="separator">/</span>
      <span class="current">{interview.data.name}</span>
    </div>

    <div class="detail-grid">
      <!-- Left Column: Image and Social -->
      <div>
        {
          interview.data.coverPhoto && (
            <img
              src={interview.data.coverPhoto}
              alt={interview.data.name}
            />
          )
        }

        <h1>{interview.data.name}</h1>
        {interview.data.title && <p class="text-accent">{interview.data.title}</p>}

        <!-- Social Links -->
        <div class="card">
          <h3>Connect</h3>
          <div class="social-links">
            {
              interview.data.twitch && (
                <a href={interview.data.twitch} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                  &rarr; Twitch
                </a>
              )
            }
            {
              interview.data.twitter && (
                <a href={interview.data.twitter} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                  &rarr; Twitter
                </a>
              )
            }
            {
              interview.data.youtube && (
                <a href={interview.data.youtube} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                  &rarr; YouTube
                </a>
              )
            }
            {
              interview.data.instagram && (
                <a href={interview.data.instagram} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                  &rarr; Instagram
                </a>
              )
            }
            {
              interview.data.discord && (
                <a href={interview.data.discord} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                  &rarr; Discord
                </a>
              )
            }
          </div>

          <!-- Stats -->
          {
            (interview.data.followers || interview.data.views) && (
              <div class="stats-section">
                {interview.data.followers && (
                  <div class="stat-row">
                    <span class="stat-label">Followers:</span>
                    <span class="stat-value"> {interview.data.followers}</span>
                  </div>
                )}
                {interview.data.views && (
                  <div class="stat-row">
                    <span class="stat-label">Views:</span>
                    <span class="stat-value"> {interview.data.views}</span>
                  </div>
                )}
              </div>
            )
          }
        </div>
      </div>

      <!-- Right Column: Interview Content -->
      <div>
        <article class="article-content">
          <Content />
        </article>
      </div>
    </div>

    <!-- Back Link -->
    <div class="back-link-section">
      <a href="/interviews/" class="btn btn-secondary">&larr; Back to Interviews</a>
    </div>
  </div>
</div>

<!-- Schema Markup -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Interview: {interview.data.name}",
    "description": "{interview.data.title}",
    "image": "{interview.data.coverPhoto}",
    "datePublished": "{interview.data.publishDate}"
  }
</script>

<style>
  .article-content :global(h2) {
    color: #ffffff;
    font-size: 1.5rem;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }

  .article-content :global(h3) {
    color: #ffffff;
    font-size: 1.25rem;
    margin-top: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .article-content :global(p) {
    margin-bottom: 1rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-left: 2rem;
    margin-bottom: 1rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(a) {
    color: #a855f7;
    text-decoration: underline;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid #a855f7;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #b0b0b8;
    font-style: italic;
  }
</style>
</BaseLayout>
