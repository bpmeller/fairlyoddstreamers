---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const bots = await getCollection('bots');
const sorted = bots.sort((a, b) => (b.data.rank || 0) - (a.data.rank || 0) || a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Chat Bots for Streamers - Fairly Odd Streamers"
  description="Find the best chat bots for moderation, engagement, and stream management."
>

<div class="section-narrow">
  <div class="container">
    <h1 style="margin-bottom: 1rem;">Chat Bots</h1>
    <p style="font-size: 1.1rem; color: #b0b0b8; margin-bottom: 3rem;">
      Automate chat moderation and engagement with these powerful bot platforms.
    </p>

    <div class="grid grid-3">
      {
        sorted.map((bot) => (
          <div class="card" style="display: flex; flex-direction: column; height: 100%; background: #1a1a1a; border: 1px solid #333; border-radius: 8px; overflow: hidden;">
            {bot.data.photo && (
              <div style="width: 100%; height: 200px; background: #0a0a0a; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                <img src={bot.data.photo} alt={bot.data.name} style="width: 100%; height: 100%; object-fit: cover;" />
              </div>
            )}
            <div style="padding: 1.5rem; flex: 1; display: flex; flex-direction: column;">
              <h3 style="color: #ffffff; margin: 0 0 0.5rem 0; font-size: 1.25rem;">{bot.data.name}</h3>

              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
                {bot.data.cost && (
                  <span style="display: inline-block; background: #0f766e; color: white; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">{bot.data.cost}</span>
                )}
                {bot.data.platforms && (
                  <span style="display: inline-block; background: #1e40af; color: white; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">{bot.data.platforms}</span>
                )}
              </div>

              <p style="color: #b0b0b8; font-size: 0.95rem; line-height: 1.5; margin: 0 0 1rem 0; flex: 1;">
                Powerful chat bot for moderation and engagement.
              </p>

              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                {bot.data.website && (
                  <a href={bot.data.website} target="_blank" rel="noopener noreferrer" style="display: inline-block; background: #7c3aed; color: white; padding: 0.75rem 1rem; border-radius: 4px; text-align: center; text-decoration: none; font-weight: 600; transition: background 0.2s;">
                    Visit Website →
                  </a>
                )}
                {bot.data.featuresLink && (
                  <a href={bot.data.featuresLink} target="_blank" rel="noopener noreferrer" style="display: inline-block; background: transparent; color: #7c3aed; padding: 0.5rem 1rem; border: 1px solid #7c3aed; border-radius: 4px; text-align: center; text-decoration: none; font-weight: 600; transition: all 0.2s;">
                    View Features →
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {sorted.length === 0 && <p style="text-align: center; color: #b0b0b8;">No bots found.</p>}

    <div style="margin-top: 3rem; text-align: center;">
      <a href="/resources/sponsorships/" class="btn btn-primary">Explore Sponsorships</a>
    </div>
  </div>
</div>
</BaseLayout>
