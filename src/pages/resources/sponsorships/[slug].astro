---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const sponsorships = await getCollection('sponsorships');
  return sponsorships.map((sponsor) => ({
    params: { slug: sponsor.slug },
    props: { sponsor },
  }));
}

const { sponsor } = Astro.props;
const { Content } = await sponsor.render();
---

<BaseLayout
  title={`${sponsor.data.name} - Sponsorship for Streamers`}
  description={`${sponsor.data.name} sponsorship opportunity. ${sponsor.data.category} - ${sponsor.data.type}`}
  ogImage={sponsor.data.logo}
>

<div class="section-narrow">
  <div class="container">
    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/resources/sponsorships/">Sponsorships</a>
      <span class="separator">/</span>
      <span class="current">{sponsor.data.name}</span>
    </div>

    <div class="detail-grid sponsor-detail-grid">
      <!-- Left Column: Logo and Key Info -->
      <div>
        {
          sponsor.data.logo && (
            <img
              src={sponsor.data.logo}
              alt={sponsor.data.name}
              class="sponsor-logo"
            />
          )
        }

        <h1>{sponsor.data.name}</h1>

        <!-- Key Details -->
        <div class="card">
          <div class="card-body">
            {
              sponsor.data.category && (
                <div class="detail-item">
                  <label class="detail-label">Category</label>
                  <span class="detail-value">{sponsor.data.category}</span>
                </div>
              )
            }
            {
              sponsor.data.type && (
                <div class="detail-item">
                  <label class="detail-label">Type</label>
                  <span class="badge" style="text-transform: capitalize;">
                    {sponsor.data.type}
                  </span>
                </div>
              )
            }
            {
              sponsor.data.compensation && (
                <div class="detail-item">
                  <label class="detail-label">Compensation</label>
                  <span class="text-accent">{sponsor.data.compensation}</span>
                </div>
              )
            }
            {
              sponsor.data.sponsorshipType && (
                <div class="detail-item">
                  <label class="detail-label">Sponsorship Type</label>
                  <span class="detail-value">{sponsor.data.sponsorshipType}</span>
                </div>
              )
            }
          </div>

          <!-- Action Buttons -->
          <div class="card-footer">
            {
              sponsor.data.applicationLink && (
                <a href={sponsor.data.applicationLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                  Apply Now →
                </a>
              )
            }
            {
              sponsor.data.website && (
                <a href={sponsor.data.website} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                  Visit Website
                </a>
              )
            }
          </div>
        </div>
      </div>

      <!-- Right Column: Description -->
      <div>
        <div class="card">
          <div class="card-body">
            <h2>Overview</h2>
            <div class="article-content">
              <Content />
            </div>
          </div>
        </div>

        <!-- FOS Affiliate Info -->
        {
          sponsor.data.fosAffiliate === 'Yes' && (
            <div class="card affiliate-card">
              <div class="card-body">
                <h3 class="text-accent">FOS Affiliate Program</h3>
                <p>This sponsorship is part of our affiliate network.</p>
                {sponsor.data.fosAffiliateLink && (
                  <a href={sponsor.data.fosAffiliateLink} class="btn btn-primary" style="margin-top: 1rem;">
                    Learn More
                  </a>
                )}
              </div>
            </div>
          )
        }
      </div>
    </div>

    <!-- Back Link -->
    <div class="back-link-section">
      <a href="/resources/sponsorships/" class="btn btn-secondary">← Back to All Sponsorships</a>
    </div>
  </div>
</div>

<style>
  .breadcrumb {
    margin-bottom: 2rem;
    font-size: 0.875rem;
    position: relative;
    z-index: 1;
  }
  .breadcrumb a {
    color: #a855f7;
  }
  .breadcrumb .separator {
    color: #666;
    margin: 0 0.5rem;
  }
  .breadcrumb .current {
    color: #b0b0b8;
  }
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .sponsor-logo {
    width: 100%;
    max-width: 300px;
    margin-bottom: 2rem;
    border-radius: 0.75rem;
  }
  h1 {
    margin-bottom: 1.5rem;
  }
  .card {
    margin-bottom: 2rem;
  }
  .detail-item {
    margin-bottom: 1rem;
  }
  .detail-label {
    display: block;
    color: #b0b0b8;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .detail-value {
    color: #ffffff;
  }
  .text-accent {
    color: #a855f7;
    font-weight: 600;
  }
  .card-footer {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  h2 {
    margin-bottom: 1.5rem;
  }
  .article-content {
    color: #b0b0b8;
    line-height: 1.8;
  }
  .affiliate-card {
    margin-top: 2rem;
    background-color: rgba(168, 85, 247, 0.1);
    border: 1px solid var(--accent-purple);
  }
  .affiliate-card h3 {
    margin-bottom: 1rem;
  }
  .back-link-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }
  .badge {
    display: inline-block;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    color: white;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- Schema Markup -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{sponsor.data.name}",
    "description": "{sponsor.data.category} sponsorship opportunity",
    "image": "{sponsor.data.logo}",
    "datePublished": "{sponsor.data.publishDate}",
    "author": {
      "@type": "Organization",
      "name": "Fairly Odd Streamers"
    }
  }
</script>
</BaseLayout>
