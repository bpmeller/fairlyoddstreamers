---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const sponsorships = await getCollection('sponsorships');

// Get unique categories and types
const categories = [...new Set(sponsorships.map((s) => s.data.category).filter(Boolean))].sort();
const types = [...new Set(sponsorships.map((s) => s.data.type).filter(Boolean))].sort();

const sorted = sponsorships.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Sponsorships for Streamers - Fairly Odd Streamers"
  description={`Discover ${sponsorships.length}+ sponsorship opportunities for livestreamers. Find affiliate programs and brand partnerships.`}
>

<div class="section-narrow">
  <div class="container">
    <h1>100+ Sponsorships for Streamers</h1>
    <p class="page-subtitle">
      Discover brand partnerships and affiliate programs tailored for content creators. Filter by category, type, and
      compensation.
    </p>

    <!-- Search and Filter Controls -->
    <div class="filter-bar">
      <input
        type="text"
        id="searchInput"
        placeholder="Search sponsorships by name..."
      />

      <div class="filter-row">
        <select id="categoryFilter">
          <option value="">All Categories</option>
          {
            categories.map((cat) => (
              <option value={cat}>{cat}</option>
            ))
          }
        </select>

        <select id="typeFilter">
          <option value="">All Types</option>
          {
            types.map((type) => (
              <option value={type}>{type}</option>
            ))
          }
        </select>

        <button id="resetBtn" class="btn btn-secondary">Reset Filters</button>
      </div>
    </div>

    <!-- Results counter -->
    <p id="resultsCounter" class="results-counter">
      Showing {sponsorships.length} sponsorships
    </p>

    <!-- Sponsorships Table -->
    <div class="table-wrap">
      <table id="sponsorshipsTable">
        <thead>
          <tr>
            <th>Logo</th>
            <th>Name</th>
            <th>Category</th>
            <th>Type</th>
            <th>Compensation</th>
          </tr>
        </thead>
        <tbody id="sponsorshipsBody">
          {
            sorted.map((sponsor) => (
              <tr data-name={sponsor.data.name} data-category={sponsor.data.category} data-type={sponsor.data.type}>
                <td>
                  {sponsor.data.logo ? (
                    <img
                      src={sponsor.data.logo}
                      alt={sponsor.data.name}
                      class="table-logo"
                    />
                  ) : (
                    <span class="text-muted">No logo</span>
                  )}
                </td>
                <td>
                  <a href={`/resources/sponsorships/${sponsor.slug}/`} class="text-accent">
                    {sponsor.data.name}
                  </a>
                </td>
                <td>{sponsor.data.category}</td>
                <td>
                  <span class="badge" style="text-transform: capitalize;">
                    {sponsor.data.type}
                  </span>
                </td>
                <td>{sponsor.data.compensation || '—'}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <!-- No results message -->
    <div id="noResults" class="no-results">
      <h3>No sponsorships found</h3>
      <p>Try adjusting your filters or search term</p>
    </div>

    <!-- Newsletter Signup -->
    <div class="newsletter-box">
      <h2>Stay in the Loop</h2>
      <p class="page-subtitle">
        Get the latest sponsorship opportunities, tools, and streamer tips delivered to your inbox.
      </p>
      <form action="https://formsubmit.co/brian@fairlyoddstreamers.com" method="POST" class="newsletter-form">
        <input type="text" name="_honey" style="display:none">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_subject" value="New FOS Newsletter Signup">
        <input type="hidden" name="_next" value="https://fairlyoddstreamers.com/resources/sponsorships/?subscribed=true">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
        />
        <button type="submit" class="btn btn-primary">
          Subscribe
        </button>
      </form>
      <p class="newsletter-disclaimer">No spam, unsubscribe anytime.</p>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var searchInput = document.getElementById('searchInput');
    var categoryFilter = document.getElementById('categoryFilter');
    var typeFilter = document.getElementById('typeFilter');
    var resetBtn = document.getElementById('resetBtn');
    var sponsorshipsBody = document.getElementById('sponsorshipsBody');
    var noResults = document.getElementById('noResults');
    var resultsCounter = document.getElementById('resultsCounter');

    function filterSponsors() {
      var searchTerm = searchInput.value.toLowerCase();
      var selectedCategory = categoryFilter.value;
      var selectedType = typeFilter.value;

      var visibleCount = 0;
      var rows = sponsorshipsBody.querySelectorAll('tr');

      rows.forEach(function(row) {
        var name = (row.getAttribute('data-name') || '').toLowerCase();
        var category = row.getAttribute('data-category') || '';
        var type = row.getAttribute('data-type') || '';

        var matchesSearch = name.indexOf(searchTerm) !== -1;
        var matchesCategory = !selectedCategory || category === selectedCategory;
        var matchesType = !selectedType || type === selectedType;

        if (matchesSearch && matchesCategory && matchesType) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });

      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      resultsCounter.textContent = 'Showing ' + visibleCount + ' of ' + rows.length + ' sponsorships';
    }

    function resetFilters() {
      searchInput.value = '';
      categoryFilter.value = '';
      typeFilter.value = '';
      filterSponsors();
    }

    searchInput.addEventListener('input', filterSponsors);
    categoryFilter.addEventListener('change', filterSponsors);
    typeFilter.addEventListener('change', filterSponsors);
    resetBtn.addEventListener('click', resetFilters);
  });
</script>

<style>
  .page-subtitle {
    font-size: 1.1rem;
    color: #b0b0b8;
    margin-bottom: 2rem;
  }
  .filter-bar {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .filter-bar input,
  .filter-bar select {
    padding: 0.75rem 1rem;
    font-size: 1rem;
  }
  .filter-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .filter-row select {
    flex: 1;
    min-width: 200px;
  }
  .results-counter {
    color: #b0b0b8;
    margin-bottom: 1rem;
  }
  .table-wrap {
    overflow-x: auto;
  }
  .table-logo {
    max-height: 40px;
    object-fit: contain;
  }
  .text-muted {
    color: #666;
  }
  .text-accent {
    color: #a855f7;
    font-weight: 500;
  }
  .no-results {
    display: none;
    text-align: center;
    padding: 2rem;
    background-color: var(--bg-secondary);
    border-radius: 0.75rem;
  }
  .newsletter-box {
    max-width: 600px;
    margin: 3rem auto 0;
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, rgba(168,85,247,0.15), rgba(236,72,153,0.15));
    border: 1px solid rgba(168,85,247,0.3);
    border-radius: 1rem;
  }
  .newsletter-box h2 {
    margin-bottom: 0.5rem;
  }
  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .newsletter-form input[type="email"] {
    padding: 0.75rem 1rem;
    min-width: 280px;
    font-size: 1rem;
  }
  .newsletter-form button {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
  }
  .newsletter-disclaimer {
    font-size: 0.8rem;
    color: #666;
    margin-top: 1rem;
    margin-bottom: 0;
  }
  .badge {
    display: inline-block;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    color: white;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
  }
</style>
</BaseLayout>
