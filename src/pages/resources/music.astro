---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const music = await getCollection('music');
const sorted = music.sort((a, b) => (b.data.rank || 0) - (a.data.rank || 0) || a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Free Music for Streamers - Fairly Odd Streamers"
  description="Discover free and royalty-free music libraries for your livestreams."
>

<div class="section-narrow">
  <div class="container">
    <h1 style="margin-bottom: 1rem;">Music for Streaming</h1>
    <p style="font-size: 1.1rem; color: #b0b0b8; margin-bottom: 3rem;">
      Access free and royalty-free music libraries to enhance your streams.
    </p>

    <div class="grid grid-3">
      {
        sorted.map((service) => (
          <div class="card" style="display: flex; flex-direction: column; height: 100%; background: #1a1a1a; border: 1px solid #333; border-radius: 8px; overflow: hidden;">
            {service.data.logo && (
              <div style="width: 100%; height: 200px; background: #0a0a0a; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                <img src={service.data.logo} alt={service.data.name} style="width: 100%; height: 100%; object-fit: cover;" />
              </div>
            )}
            <div style="padding: 1.5rem; flex: 1; display: flex; flex-direction: column;">
              <h3 style="color: #ffffff; margin: 0 0 0.5rem 0; font-size: 1.25rem;">{service.data.name}</h3>

              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
                {service.data.pricing && (
                  <span style="display: inline-block; background: #0f766e; color: white; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">{service.data.pricing}</span>
                )}
                {service.data.trackCount && (
                  <span style="display: inline-block; background: #7c3aed; color: white; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">{service.data.trackCount} tracks</span>
                )}
              </div>

              {service.data.shortDescription && (
                <p style="color: #b0b0b8; font-size: 0.95rem; line-height: 1.5; margin: 0 0 1rem 0; flex: 1;">
                  {service.data.shortDescription}
                </p>
              )}

              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                {service.data.homepage && (
                  <a href={service.data.homepage} target="_blank" rel="noopener noreferrer" style="display: inline-block; background: #7c3aed; color: white; padding: 0.75rem 1rem; border-radius: 4px; text-align: center; text-decoration: none; font-weight: 600; transition: background 0.2s;">
                    Visit Website →
                  </a>
                )}
                {service.data.signUpLink && (
                  <a href={service.data.signUpLink} target="_blank" rel="noopener noreferrer" style="display: inline-block; background: transparent; color: #7c3aed; padding: 0.5rem 1rem; border: 1px solid #7c3aed; border-radius: 4px; text-align: center; text-decoration: none; font-weight: 600; transition: all 0.2s;">
                    Sign Up →
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {sorted.length === 0 && <p style="text-align: center; color: #b0b0b8;">No music services found.</p>}

    <div style="margin-top: 3rem; text-align: center;">
      <a href="/resources/sponsorships/" class="btn btn-primary">Explore Sponsorships</a>
    </div>
  </div>
</div>
</BaseLayout>
