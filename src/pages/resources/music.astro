---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const music = await getCollection('music');
const sorted = music.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Free Music for Streamers - Fairly Odd Streamers"
  description="Discover free and royalty-free music libraries for your livestreams."
>

<div class="section-narrow">
  <div class="container">
    <h1 style="margin-bottom: 1rem;">Music for Streaming</h1>
    <p style="font-size: 1.1rem; color: #b0b0b8; margin-bottom: 3rem;">
      Access free and royalty-free music libraries to enhance your streams.
    </p>

    <div class="grid grid-3">
      {
        sorted.map((track) => (
          <div class="card">
            <h3 style="color: #ffffff; margin-bottom: 0.5rem;">{track.data.name}</h3>
            {track.data.website && (
              <p style="margin-bottom: 1rem;">
                <a href={track.data.website} target="_blank" rel="noopener noreferrer">
                  Visit Website →
                </a>
              </p>
            )}
            {track.data.category && <p style="color: #a855f7; font-weight: 600;">{track.data.category}</p>}
          </div>
        ))
      }
    </div>

    {sorted.length === 0 && <p style="text-align: center; color: #b0b0b8;">No music services found.</p>}

    <div style="margin-top: 3rem; text-align: center;">
      <a href="/resources/sponsorships/" class="btn btn-primary">Explore Sponsorships</a>
    </div>
  </div>
</div>
</BaseLayout>
