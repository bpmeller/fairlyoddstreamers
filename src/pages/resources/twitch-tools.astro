---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const streamingTools = await getCollection('streaming-tools');
const sorted = streamingTools.sort((a, b) => (a.data.order || 0) - (b.data.order || 0) || a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Twitch Tools & Extensions - Fairly Odd Streamers"
  description="Essential tools and extensions for Twitch streamers."
>

<div class="section-narrow">
  <div class="container">
    <h1>Streaming Platform Tools</h1>
    <p class="page-subtitle">
      Platform-specific tools and extensions to enhance your streaming experience.
    </p>

    <div class="grid grid-3">
      {
        sorted.map((tool) => (
          <div class="card resource-card">
            {tool.data.logo && (
              <div class="resource-card-image">
                <img src={tool.data.logo} alt={tool.data.name} />
              </div>
            )}
            <div class="resource-card-body">
              <h3>{tool.data.name}</h3>

              <div class="resource-card-tags">
                {tool.data.toolCategory && (
                  <span class="tag tag-teal">{tool.data.toolCategory}</span>
                )}
              </div>

              {tool.data.toolDescription && (
                <p class="resource-card-desc">
                  {tool.data.toolDescription}
                </p>
              )}

              <div class="resource-card-actions">
                {tool.data.link && (
                  <a href={tool.data.link} target="_blank" rel="noopener noreferrer" class="btn-resource">
                    Visit Website →
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {sorted.length === 0 && <p class="empty-state">No streaming tools found.</p>}

    <div class="cta-center">
      <a href="/resources/sponsorships/" class="btn btn-primary">Explore Sponsorships</a>
    </div>
  </div>
</div>
</BaseLayout>
