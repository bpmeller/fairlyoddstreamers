---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blog = await getCollection('blog');
const sorted = blog.sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime());
---

<BaseLayout
  title="Blog - Fairly Odd Streamers"
  description="Tips, guides, and insights for livestreamers. Read the latest articles about streaming, sponsorships, and content creation."
>

<div class="section-narrow">
  <div class="container">
    <div class="page-header">
      <h1>Blog</h1>
    </div>
    <p class="page-subtitle">
      Tips, guides, and insights for livestreamers.
    </p>

    {
      sorted.length > 0 ? (
        <div class="grid grid-2">
          {sorted.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card card-link">
              {post.data.coverImage && (
                <img
                  src={post.data.coverImage}
                  alt={post.data.name}
                  class="card-img"
                />
              )}
              <h3 class="card-title">{post.data.name}</h3>
              <p class="line-clamp-2">{post.data.postSummary || ''}</p>
              <div class="card-meta">
                <div>
                  {post.data.author && <span>{post.data.author}</span>}
                  {post.data.publishDate && <span> • {new Date(post.data.publishDate).toLocaleDateString()}</span>}
                </div>
                {post.data.readTime && <span>{post.data.readTime}</span>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">No blog posts found.</p>
      )
    }
  </div>
</div>
</BaseLayout>
