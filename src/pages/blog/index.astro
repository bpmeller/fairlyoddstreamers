---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blog = await getCollection('blog');
const sorted = blog.sort((a, b) => new Date(b.data.publishDate || 0).getTime() - new Date(a.data.publishDate || 0).getTime());
---

<BaseLayout
  title="Blog - Fairly Odd Streamers"
  description="Tips, guides, and insights for livestreamers. Read the latest articles about streaming, sponsorships, and content creation."
>

<div class="section-narrow">
  <div class="container">
    <h1 style="margin-bottom: 1rem;">Blog</h1>
    <p style="font-size: 1.1rem; color: #b0b0b8; margin-bottom: 3rem;">
      Tips, guides, and insights for livestreamers.
    </p>

    {
      sorted.length > 0 ? (
        <div class="grid grid-2">
          {sorted.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card" style="text-decoration: none; display: block;">
              {post.data.coverImage && (
                <img
                  src={post.data.coverImage}
                  alt={post.data.name}
                  style="width: 100%; height: 200px; object-fit: cover; margin: -1rem -1rem 1rem -1rem; border-radius: 0.75rem 0.75rem 0 0;"
                />
              )}
              <h3 style="color: #ffffff; margin-bottom: 0.5rem;">{post.data.name}</h3>
              <p class="line-clamp-2">{post.data.postSummary || ''}</p>
              <div
                style="margin-top: 1rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.875rem; color: #b0b0b8;"
              >
                <div>
                  {post.data.author && <span>{post.data.author}</span>}
                  {post.data.publishDate && <span> • {new Date(post.data.publishDate).toLocaleDateString()}</span>}
                </div>
                {post.data.readTime && <span>{post.data.readTime}</span>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: #b0b0b8;">No blog posts found.</p>
      )
    }
  </div>
</div>
</BaseLayout>
