---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blog = await getCollection('blog');
  return blog.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.name} - Fairly Odd Streamers Blog`}
  description={post.data.metaDescription || post.data.postSummary || 'Read this article on Fairly Odd Streamers'}
  ogImage={post.data.ogImage || post.data.coverImage}
>

<div class="section-narrow">
  <div class="container">
    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/blog/">Blog</a>
      <span class="separator">/</span>
      <span class="current">{post.data.name}</span>
    </div>

    <!-- Article Container -->
    <article class="article-container">
      <!-- Header -->
      <h1>{post.data.name}</h1>

      <!-- Meta Info -->
      <div class="article-meta">
        {
          post.data.publishDate && (
            <div>
              {new Date(post.data.publishDate).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </div>
          )
        }
        {post.data.readTime && <div>{post.data.readTime}</div>}
        {
          post.data.category && (
            <div>
              <span class="badge badge-secondary">{post.data.category}</span>
            </div>
          )
        }
      </div>

      <!-- Featured Image -->
      {
        post.data.coverImage && (
          <img
            src={post.data.coverImage}
            alt={post.data.name}
            class="article-cover"
          />
        )
      }

      <!-- Content -->
      <div class="article-content prose">
        <Content />
      </div>

      <!-- End of Article -->
      <hr class="article-divider" />

      <!-- Back Link -->
      <div class="back-link">
        <a href="/blog/" class="btn btn-secondary">&larr; Back to Blog</a>
      </div>
    </article>
  </div>
</div>

<!-- Schema Markup -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{post.data.name}",
    "description": "{post.data.postSummary || post.data.metaDescription}",
    "image": "{post.data.coverImage}",
    "author": {
      "@type": "Person",
      "name": "{post.data.author}"
    },
    "datePublished": "{post.data.publishDate}"
  }
</script>

<style>
  .prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #ffffff;
    font-size: 1.75rem;
  }

  .prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #ffffff;
    font-size: 1.35rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-left: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(a) {
    color: #a855f7;
    text-decoration: underline;
  }

  .prose :global(a:hover) {
    color: #ec4899;
  }

  .prose :global(blockquote) {
    border-left: 4px solid #a855f7;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #b0b0b8;
    font-style: italic;
  }

  .prose :global(code) {
    background-color: var(--bg-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    color: #a1ffc5;
  }

  .prose :global(pre) {
    background-color: var(--bg-secondary);
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
</style>
</BaseLayout>
