---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blog = await getCollection('blog');
  return blog.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.name} - Fairly Odd Streamers Blog`}
  description={post.data.metaDescription || post.data.postSummary || 'Read this article on Fairly Odd Streamers'}
  ogImage={post.data.ogImage || post.data.coverImage}
>

<div class="section-narrow">
  <div class="container">
    <!-- Breadcrumb -->
    <div style="margin-bottom: 2rem; font-size: 0.875rem; position: relative; z-index: 1;">
      <a href="/blog/" style="color: #a855f7;">Blog</a>
      <span style="color: #666; margin: 0 0.5rem;">/</span>
      <span style="color: #b0b0b8;">{post.data.name}</span>
    </div>

    <!-- Article Container -->
    <article style="max-width: 700px; margin: 0 auto;">
      <!-- Header -->
      <h1 style="margin-bottom: 1rem;">{post.data.name}</h1>

      <!-- Meta Info -->
      <div style="display: flex; gap: 2rem; margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border-color); flex-wrap: wrap; color: #b0b0b8; font-size: 0.9rem;">
        {
          post.data.author && (
            <div>
              <strong style="color: #ffffff;">By</strong> {post.data.author}
            </div>
          )
        }
        {
          post.data.publishDate && (
            <div>
              {new Date(post.data.publishDate).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </div>
          )
        }
        {post.data.readTime && <div>{post.data.readTime}</div>}
        {
          post.data.category && (
            <div>
              <span class="badge badge-secondary">{post.data.category}</span>
            </div>
          )
        }
      </div>

      <!-- Featured Image -->
      {
        post.data.coverImage && (
          <img
            src={post.data.coverImage}
            alt={post.data.name}
            style="width: 100%; border-radius: 0.75rem; margin-bottom: 2rem; max-height: 400px; object-fit: cover;"
          />
        )
      }

      <!-- Content -->
      <div
        style="color: #b0b0b8; line-height: 1.8; font-size: 1.05rem;"
        class="prose"
      >
        <Content />
      </div>

      <!-- End of Article -->
      <hr style="margin: 3rem 0; border: none; border-top: 1px solid var(--border-color);" />

      <!-- Back Link -->
      <div style="margin-top: 2rem;">
        <a href="/blog/" class="btn btn-secondary">← Back to Blog</a>
      </div>
    </article>
  </div>
</div>

<!-- Schema Markup -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{post.data.name}",
    "description": "{post.data.postSummary || post.data.metaDescription}",
    "image": "{post.data.coverImage}",
    "author": {
      "@type": "Person",
      "name": "{post.data.author}"
    },
    "datePublished": "{post.data.publishDate}"
  }
</script>

<style>
  .prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #ffffff;
    font-size: 1.75rem;
  }

  .prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #ffffff;
    font-size: 1.35rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-left: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(a) {
    color: #a855f7;
    text-decoration: underline;
  }

  .prose :global(a:hover) {
    color: #ec4899;
  }

  .prose :global(blockquote) {
    border-left: 4px solid #a855f7;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #b0b0b8;
    font-style: italic;
  }

  .prose :global(code) {
    background-color: var(--bg-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    color: #a1ffc5;
  }

  .prose :global(pre) {
    background-color: var(--bg-secondary);
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
</style>
</BaseLayout>
